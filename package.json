{
  "name": "vercel-secret-audit",
  "version": "0.1.1",
  "private": true,
  "description": "Local audit CLI for Vercel environment variables, likely secrets, and post-breach rotation checks.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "vercel-secret-audit": "./src/cli.mjs"
  },
  "scripts": {
    "check": "node --check src/*.mjs",
    "start": "node ./src/cli.mjs",
    "audit": "node ./src/cli.mjs",
    "smoke": "bash ./scripts/smoke-test.sh"
  },
  "keywords": [
    "vercel",
    "security",
    "secrets",
    "audit",
    "incident-response",
    "env",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mitchmalone/vercel-secret-audit.git"
  },
  "bugs": {
    "url": "https://github.com/mitchmalone/vercel-secret-audit/issues"
  },
  "homepage": "https://github.com/mitchmalone/vercel-secret-audit",
  "license": "MIT"
}
